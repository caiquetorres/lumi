fun main() {
    let firstName = "Jane";
    let lastName = "Doe";

    let name = getPreferredName(firstName, lastName);
    let greeting = buildGreeting(name);

    printf("%s\n", greeting);
}

fun getPreferredName(first string, last string) string {
    return first;
}

fun buildGreeting(name string) string {
    return sprintf("Hello, %s!", name);
}
