  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Compilation",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "main.go",
      "args": ["compile", "--file", "main.lumi", "--out", "bin"],
      "cwd": "."
    },
    {
      "name": "Debug Exec",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "main.go",
      "args": ["run", "--exec", "bin"],
      "cwd": "."
    }
  ]
}
