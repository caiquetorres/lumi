fun main() {
    let i = 1
    while i <= 20 {
        fizzbuzz(i)
        i = i + 1
    }
}

fun fizzbuzz(n int) {
    let divBy3 = n / 3 * 3 == n
    let divBy5 = n / 5 * 5 == n

    if divBy3 {
        if divBy5 {
            printf("%d FizzBuzz\n", n)
            return
        }

        printf("%d Fizz\n", n)
        return
    }

    if divBy5 == true {
        printf("%d Buzz\n", n)
        return
    }

    println(n)
}
