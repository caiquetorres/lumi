fun main() {
    for i in 2..=20 {
        if isPrime(i) {
            printf("%d is prime\n", i)
        }
    }
}

fun isPrime(n int) {
    if n < 2 {
        return false
    }
    let i = 2
    while i * i <= n {
        if n / i * i == n {
            return false
        }
        i += 1
    }
    return true
}
