fun main() {
    for let n = 1; n <= 15; n += 1 {
        let steps = collatz(n)
        printf("collatz(%d): %d steps\n", n, steps)
    }
}

fun collatz(n int) int {
    let steps = 0
    while n != 1 {
        if n / 2 * 2 == n {
            n /= 2
        } else {
            n = 3 * n + 1
        }
        steps += 1
    }
    return steps
}
